{
    "name": "fyler",
    "private": true,
    "version": "1.0.0",
    "description": "Desktop app for merging PDF files and images into a single PDF, built with Tauri 2.",
    "license": "MIT",
    "author": "gualask",
    "homepage": "https://github.com/gualask/fyler",
    "repository": {
        "type": "git",
        "url": "https://github.com/gualask/fyler.git"
    },
    "bugs": {
        "url": "https://github.com/gualask/fyler/issues"
    },
    "packageManager": "pnpm@11.9.0",
    "type": "module",
    "scripts": {
        "format": "biome format --write .",
        "i18n:check": "node scripts/check-i18n.mjs",
        "lint": "biome check .",
        "test": "vitest run",
        "test:watch": "vitest",
        "typecheck": "tsc --noEmit -p tsconfig.json",
        "dev": "vite",
        "build": "pnpm typecheck && vite build",
        "build:standalone": "pnpm typecheck && vite build --mode standalone",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "tauri:build": "tauri build",
        "tauri:build:standalone": "node scripts/build-standalone.mjs"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
        "@tabler/icons-react": "^3.44.0",
        "@tauri-apps/api": "^2.11.1",
        "@tauri-apps/plugin-process": "^2.3.1",
        "@tauri-apps/plugin-store": "^2.4.3",
        "@tauri-apps/plugin-updater": "^2.10.1",
        "motion": "^12.42.0",
        "pdfjs-dist": "^6.0.227",
        "react": "^19.2.7",
        "react-dom": "^19.2.7"
    },
    "devDependencies": {
        "@biomejs/biome": "2.5.1",
        "@rolldown/plugin-transform-imports": "^0.1.1",
        "@tailwindcss/vite": "^4.3.1",
        "@tauri-apps/cli": "^2.11.3",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.17",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.3",
        "tailwindcss": "^4.3.1",
        "typescript": "~6.0.3",
        "vite": "^8.1.0",
        "vitest": "^4.1.9"
    }
}
